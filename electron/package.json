{
  "name": "faceit-demo-manager",
  "version": "1.0.0",
  "description": "FACEIT Demo Manager for CS2 — manage demos, generate voice presets",
  "author": "ArdianHajdini",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArdianHajdini/Faceit_esayDemo.git"
  },
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "start": "electron .",
    "dist:win": "electron-builder --win --config electron-builder.json --publish=never",
    "dist:mac": "electron-builder --mac --config electron-builder.json",
    "dist:linux": "electron-builder --linux --config electron-builder.json"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.9.3"
  }
}
